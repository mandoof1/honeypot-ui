# HoneySentinel AI - Environment Configuration
# Copy this file to .env and update values as needed

# Database
DATABASE_URL=postgresql+asyncpg://honeypot:honeypot@localhost:5433/honeysentinel
DATABASE_URL_SYNC=postgresql+psycopg2://honeypot:honeypot@localhost:5433/honeysentinel

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT Authentication
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (32-byte key for AES-256 via Fernet)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Email Alerts (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Webhook Alerts
WEBHOOK_URL=

# GeoIP (download from MaxMind)
GEOIP_DB_PATH=./data/GeoLite2-City.mmdb

# Honeypot APIs
COWRIE_API_URL=http://localhost:9090
DIONAEA_API_URL=http://localhost:8080

# AI Models
MODEL_PATH_RF=./models/random_forest_model.pkl
MODEL_PATH_IF=./models/isolation_forest_model.pkl
SPACY_MODEL=en_core_web_sm

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
